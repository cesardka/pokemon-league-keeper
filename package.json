{
  "name": "creed",
  "version": "0.1.0",
  "private": true,
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
  },
  "scripts": {
    "dev": "next dev --port 1996",
    "build": "prisma generate && next build",
